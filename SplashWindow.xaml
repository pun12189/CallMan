<Window x:Class="BahiKitab.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BahiKitab"
        mc:Ignorable="d"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="450" Height="250" WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Border CornerRadius="15" Background="#2193b0">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="CALLMAN APP" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,20,0,0" Background="Transparent" BorderThickness="0" Foreground="White"/>
                <TextBlock Text="Initializing services..." Foreground="White" Opacity="0.7" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
