<Window x:Class="BahiKitab.Views.ProductLookupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BahiKitab.Views"
        mc:Ignorable="d"
        Title="Select Product" Height="450" Width="500" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Search Product" FontWeight="Bold" Margin="0,0,0,5"/>
            <DockPanel>
                <Button Content="+" Command="{Binding ToggleAddFormCommand}" DockPanel.Dock="Right" Width="30" Margin="5,0,0,0" Background="#3498DB" Foreground="White"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="#F9F9F9" Margin="0,10" Padding="10" CornerRadius="5"
                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Quick Create New Product" FontWeight="SemiBold" Foreground="#2980B9" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,5,0">
                        <Label Content="New Product Name" FontSize="10"/>
                        <TextBox Text="{Binding NewProductName}" Height="25"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Label Content="HSN Code" FontSize="10"/>
                        <TextBox Text="{Binding NewHSN}" Height="25"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Short Code" FontSize="10"/>
                        <TextBox Text="{Binding NewCode}" Height="25"/>
                    </StackPanel>
                </Grid>
                <Button Content="Add &amp; Select" Command="{Binding SaveNewProductCommand}" 
                        Background="#27AE60" Foreground="White" Height="30" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <ListBox Grid.Row="2" Margin="0,10" ItemsSource="{Binding FilteredProducts}" 
                 SelectedItem="{Binding SelectedProduct}" DisplayMemberPath="Name">
            <ListBox.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding SelectProductCommand}"/>
            </ListBox.InputBindings>
        </ListBox>

        <Button Grid.Row="3" Content="Use Selected Item" Command="{Binding SelectProductCommand}" 
                Height="35" Background="#2C3E50" Foreground="White"/>
    </Grid>
</Window>
