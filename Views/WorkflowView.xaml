<UserControl x:Class="BahiKitab.Views.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BahiKitab.Views"
             xmlns:helper="clr-namespace:BahiKitab.Helper"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800" Background="White">
    <UserControl.Resources>
        <helper:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </UserControl.Resources>

    <TabControl>
        <TabItem Header="Workflow Automation Settings" IsSelected="True">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Workflow Automation Settings" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                    <TextBlock Text="Set up automatic messages for leads, invoices, and tasks." Foreground="Gray" Margin="0,0,0,25"/>

                    <Label Content="1. When this event occurs:" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding EventList}" 
                  SelectedItem="{Binding SelectedEvent}" 
                  DisplayMemberPath="DisplayName" 
                  Height="35" Margin="0,5,0,20" 
                  VerticalContentAlignment="Center"/>

                    <Label Content="2. Send notification via:" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                        <CheckBox Content="WhatsApp" IsChecked="{Binding CurrentRule.SendWhatsApp}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Email" IsChecked="{Binding CurrentRule.SendEmail}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Label Content="3. Message Content:" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CurrentRule.MessageTemplate, UpdateSourceTrigger=PropertyChanged}" 
                 Height="150" TextWrapping="Wrap" AcceptsReturn="True" 
                 VerticalScrollBarVisibility="Auto" Padding="10" Margin="0,5,0,5"
                 BorderBrush="#BDC3C7" BorderThickness="1"/>

                    <TextBlock Text="Tip: Use curly braces for dynamic data, e.g., {Name} or {Amount}" 
                   FontSize="11" FontStyle="Italic" Foreground="#7F8C8D" Margin="0,0,0,20"/>

                    <Button Command="{Binding SaveCommand}" 
                Content="Save Automation Rule" 
                Height="45" Background="#27AE60" Foreground="White" 
                FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1" Background="#F8F9F9" Padding="15" CornerRadius="8" BorderBrush="#EBEDEF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Available Placeholders" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Based on the selected event, you can use these tags in your message:" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding PlaceholderSuggestions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#D5F5E3" Margin="0,2" Padding="5" CornerRadius="3">
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" Foreground="#1D8348"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>                
            </Grid>
        </TabItem>

        <TabItem Header="Active Workflows">
            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,0,10,0">
                <TextBlock Text="Active Workflows" FontSize="18" FontWeight="Bold" Margin="0,30,0,10"/>

                <DataGrid ItemsSource="{Binding SavedRules}" AutoGenerateColumns="False" 
CanUserAddRows="False" Background="White" Height="250"
BorderBrush="#DCDCDC" BorderThickness="1" RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Event Name" Binding="{Binding EventKey}" Width="150" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="Status" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" 
                    HorizontalAlignment="Center"
                    Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Template Preview" Binding="{Binding MessageTemplate}" Width="*" IsReadOnly="True"/>

                        <DataGridTemplateColumn Header="Channels" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="WA" Foreground="{Binding SendWhatsApp, Converter={StaticResource BoolToColorConverter}}" Margin="0,0,10,0" FontWeight="Bold"/>
                                        <TextBlock Text="Email" Foreground="{Binding SendEmail, Converter={StaticResource BoolToColorConverter}}" FontWeight="Bold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </TabItem>
    </TabControl>

    
</UserControl>
