<UserControl x:Class="BahiKitab.Views.LeadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BahiKitab.Views"
             xmlns:core="clr-namespace:BahiKitab.Core"
             xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:helper="clr-namespace:BahiKitab.Helper"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <core:IdToButtonTextConverter x:Key="IdToButtonTextConverter"/>
        <core:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="10">

        <!-- Left Column: Leads List (DataGrid) -->
        <StackPanel Margin="0,0,10,0">
            <TextBlock Text="CRM Leads Management" Style="{StaticResource TitleStyle}" FontSize="24" FontWeight="Bold"/>

            <!-- Command Buttons for List -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
                <TextBox x:Name="tbSearch" Margin="0,0,5,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Width="250" Height="35" controls:TextBoxHelper.Watermark="Search" controls:TextBoxHelper.ClearTextButton="True"/>

                <Button Command="{Binding LoadLeadsCommand}" Style="{StaticResource KlikButtonStyle}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="RotateSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh Leads" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding ImportLeadsCommand}" Style="{StaticResource KlikButtonStyle}" Visibility="Visible">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Format" Click="MenuItem_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="ArrowUpFromBracketSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Import" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding NewLeadCommand}" Style="{StaticResource KlikButtonStyle}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="PlusSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="New Lead" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <StackPanel>
                    <Menu Background="#20b2aa" Margin="5" Height="35" VerticalContentAlignment="Center" Foreground="White" FontSize="14" FontFamily="Segoe UI" FontWeight="Bold">
                        <MenuItem Header="Show/Hide Columns" ItemsSource="{Binding ColumnList}" Height="35" VerticalContentAlignment="Center">
                            <MenuItem.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="StaysOpenOnClick" Value="True" />
                                </Style>
                            </MenuItem.ItemContainerStyle>
                            <MenuItem.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Header}" IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                </DataTemplate>
                            </MenuItem.ItemTemplate>
                        </MenuItem>
                        <MenuItem Header="Reset" Margin="5,0" Height="35" Command="{Binding ResetColumnsCommand}" Foreground="Red" />
                    </Menu>
                </StackPanel>
            </StackPanel>
            <!-- Data Grid to display Leads -->
            <DataGrid ItemsSource="{Binding ProductView}" x:Name="dataGrid1"
                  SelectedItem="{Binding SelectedLead, Mode=TwoWay}"
                      AlternatingRowBackground="Cornsilk"
                  AutoGenerateColumns="False"
                      CanUserAddRows="False"
                  Height="450"
                  SelectionMode="Single"
                      SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                      ScrollViewer.CanContentScroll="True" 
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <!--<DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Style.Triggers>-->
                        <!-- Assuming your data item has a boolean property named IsDeleted --><!--
                            <DataTrigger Binding="{Binding LeadType}" Value="{x:Static helper:LeadType.Dead}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LeadType}" Value="{x:Static helper:LeadType.Matured}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LeadType}" Value="{x:Static helper:LeadType.FollowUp}">
                                <Setter Property="Background" Value="LightBlue"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LeadType}" Value="{x:Static helper:LeadType.New}">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>-->
                <DataGrid.Columns>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.Header>
                            <CheckBox x:Name="cbAll" HorizontalAlignment="Center" VerticalAlignment="Center" Checked="cbAll_Checked" Unchecked="cbAll_Unchecked"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}, Path=IsSelected, Mode=OneWay}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Name" Width="*" IsReadOnly="True" Visibility="{Binding Data.Columns[NAME].IsVisible, 
                                 Source={StaticResource Proxy}, 
                                 Converter={StaticResource BoolToVis}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Company, StringFormat=({0})}" FontSize="10" Margin="0,5,0,0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,5,5"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">                                       
                                        <Button BorderThickness="0" ToolTip="Update Info" Command="{Binding DataContext.UpdateInfoCommand, RelativeSource={RelativeSource AncestorType=local:LeadsView}}" HorizontalAlignment="Center" Background="Transparent" Foreground="DarkSlateGray" FontWeight="Bold" Margin="5,0">
                                            <icon:BootstrapIcons Kind="JournalText"/>
                                        </Button>
                                        <Button BorderThickness="0" ToolTip="Edit Info" Command="{Binding DataContext.UpdateLeadCommand, RelativeSource={RelativeSource AncestorType=local:LeadsView}}" HorizontalAlignment="Center" Background="Transparent" Foreground="DarkSlateGray" FontWeight="Bold" Margin="5,0">
                                            <icon:BootstrapIcons Kind="PencilFill"/>
                                        </Button>
                                        <Button BorderThickness="0" ToolTip="Delete" Command="{Binding DataContext.DeleteLeadCommand, RelativeSource={RelativeSource AncestorType=local:LeadsView}}" HorizontalAlignment="Center" Background="Transparent" Foreground="DarkSlateGray" FontWeight="Bold" Margin="5,0">
                                            <icon:BootstrapIcons Kind="Trash3Fill"/>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding CreationDate, StringFormat={}{0:dd/MM/yyyy}}" FontWeight="Bold" Margin="0,10,0,5"/>
                                    <!--<TextBlock HorizontalAlignment="Center" Text="{Binding Id, StringFormat=ID: {0}}" FontWeight="Bold" Margin="0,0,0,10"/>-->
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Contact" Width="*" IsReadOnly="True" Visibility="{Binding Data.Columns[CONTACT].IsVisible, 
                                 Source={StaticResource Proxy}, 
                                 Converter={StaticResource BoolToVis}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>                                    
                                    <icon:PackIconFontAwesome Kind="PhoneSolid" Grid.Row="1" Grid.Column="0" FontSize="14" FontWeight="Bold" Visibility="{Binding ElementName=WhatsApp, Path=Visibility}"/>
                                    <icon:PackIconMaterial Kind="Email" Grid.Row="2" Grid.Column="0" FontSize="14" FontWeight="Bold" Visibility="{Binding ElementName=Email, Path=Visibility}"/>
                                    <icon:PackIconMaterial Kind="MapMarker" Grid.Row="3" Grid.Column="0" FontSize="14" FontWeight="Bold" Visibility="{Binding ElementName=Map, Path=Visibility}"/>
                                    <StackPanel x:Name="WhatsApp" Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Phone}" TextWrapping="Wrap" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                        <Button BorderThickness="0" Command="{Binding DataContext.WhatsappCommand, RelativeSource={RelativeSource AncestorType=local:LeadsView}}" CommandParameter="{Binding}" Background="Transparent" Margin="5,0" Padding="5" Foreground="Green">
                                            <icon:FontAwesome6 Kind="WhatsappBrands"/>
                                        </Button>
                                    </StackPanel>                                    
                                    <TextBlock x:Name="Email" Text="{Binding Email}" Grid.Row="2" Grid.Column="2" FontSize="14"/>
                                    <StackPanel x:Name="Map" Orientation="Vertical" Grid.Row="3" Grid.Column="2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding City, StringFormat='{}{0}\, '}" FontSize="12" Margin="0" />
                                            <TextBlock Text="{Binding District, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding State, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                            <TextBlock Text="{Binding Pincode, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                        </StackPanel>                                        
                                        <TextBlock Text="{Binding Country}" FontSize="12" Margin="0"/>
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Phone}" Value="{x:Null}">
                                        <Setter TargetName="WhatsApp" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Phone}" Value="">
                                        <Setter TargetName="WhatsApp" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Email}" Value="{x:Null}">
                                        <Setter TargetName="Email" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Email}" Value="">
                                        <Setter TargetName="Email" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="{x:Null}">
                                        <Setter TargetName="Map" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="">
                                        <Setter TargetName="Map" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Lead Info" Width="*" IsReadOnly="True" Visibility="{Binding Data.Columns[LEADINFO].IsVisible, 
                                 Source={StaticResource Proxy}, 
                                 Converter={StaticResource BoolToVis}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="LeadSource: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tag: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Label: " Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="LeadHolder: " Grid.Row="3" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LeadSource.Name}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Tags.Name}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label.Name}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LeadHolder.FullName}" TextWrapping="Wrap" Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                </Grid>
                                
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Lead Type" Width="*" IsReadOnly="True" Visibility="{Binding Data.Columns[FOLLOWUP].IsVisible, 
                                 Source={StaticResource Proxy}, 
                                 Converter={StaticResource BoolToVis}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Next FollowUp: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center" Visibility="{Binding ElementName=fpt, Path=Visibility}"/>
                                    <TextBlock Text="Status: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Followup Stage: " Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center" Visibility="{Binding ElementName=fpstage, Path=Visibility}"/>
                                    <TextBlock x:Name="fpt" Text="{Binding LeadFollowUpModel.NextFollowUp, StringFormat={}{0:dd/MM/yyyy}}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Status.Name}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0,5" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="fpstage" Text="{Binding LeadFollowUpModel.Name}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>                                    
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding LeadType}" Value="{x:Static helper:LeadType.New}">
                                        <Setter TargetName="fpt" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="fpstage" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Last Message" Width="*" IsReadOnly="True" Visibility="{Binding Data.Columns[LEADHOLDER].IsVisible, 
                                 Source={StaticResource Proxy}, 
                                 Converter={StaticResource BoolToVis}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>                                    
                                    <TextBlock Text="{Binding LeadFollowUpModel.LastMsg}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="12" Margin="0" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                                        <TextBlock Text="{Binding LeadHolder.FullName}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" Margin="0,10" VerticalAlignment="Center"/>
                                        <TextBlock Text=" | " VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding LeadFollowUpModel.CreateFollowUp, StringFormat={}{0:dd/MM/yyyy}}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="12" Margin="0" VerticalAlignment="Center"/>
                                    </StackPanel>                                    
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!--<DataGridTemplateColumn Header="Extra Info" Width="*" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Creation Date: " Grid.Row="0" Grid.Column="0" FontSize="12" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Last Updated: " Grid.Row="1" Grid.Column="0" FontSize="12" Margin="0" VerticalAlignment="Center"/>

                                    <TextBlock Text="{Binding CreationDate, StringFormat=F}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="12" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding UpdationDate, StringFormat=F}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="12" FontWeight="Bold" Margin="0,10" VerticalAlignment="Center"/>
                                    
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>-->
                    <!--<DataGridTextColumn Header="Lead Source" Binding="{Binding LeadSource.Name}" Width="*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Tags" Binding="{Binding Tags.Name}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label.Name}" Width="*" IsReadOnly="True"/>-->
