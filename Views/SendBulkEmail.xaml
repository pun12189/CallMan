<Window x:Class="BahiKitab.Views.SendBulkEmail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BahiKitab.Views"
        mc:Ignorable="d"
        Title="Send Bulk Email" Height="380" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Subject" FontWeight="Bold"/>
            <TextBox x:Name="tbSub" Text="{Binding Subject}" Height="35" FontSize="14" VerticalContentAlignment="Center"/>

            <TextBlock Text="Message (Use [Name] for personalization)" FontWeight="Bold"/>
            <TextBox Text="{Binding Body}" Height="150" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Content="📎 Attach File" Command="{Binding AttachFileCommand}" Width="100"/>
                <TextBlock Text="{Binding AttachmentPath}" VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
            </StackPanel>

            <!--<ProgressBar Value="{Binding ProgressValue}" Maximum="{Binding TotalLeads}" Height="15" Margin="0,10"/>-->

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Send to All" Click="Button_Click" Background="Green" Foreground="White" Width="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
