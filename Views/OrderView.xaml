                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding City, StringFormat='{}{0}\, '}" FontSize="12" Margin="0" />
                                            <TextBlock Text="{Binding District, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding State, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                            <TextBlock Text="{Binding Pincode, StringFormat='{}{0}\, '}" FontSize="12" Margin="0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Country}" FontSize="12" Margin="0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>-->
                    <DataGridTemplateColumn Header="Customer" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Name: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Contact: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Email: " Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    
                                    <TextBlock Text="{Binding Customer.Name}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <StackPanel x:Name="WhatsApp" Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="{Binding Customer.Phone}" TextWrapping="Wrap" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                        <Button BorderThickness="0" Command="{Binding DataContext.WhatsappCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" CommandParameter="{Binding}" Background="Transparent" Margin="5,0" Padding="5" Foreground="Green">
                                            <icon:FontAwesome6 Kind="WhatsappBrands"/>
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Customer.Email}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>                                    
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Customer.Phone}" Value="{x:Null}">
                                        <Setter TargetName="WhatsApp" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Customer.Phone}" Value="">
                                        <Setter TargetName="WhatsApp" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Order info" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Order Value: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Payment: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Balance: " Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding OrderAmount}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ReceivedAmount}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0,10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Balance}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="FollowUp" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Last Message: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Status: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Next FollowUp: " Grid.Row="2" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LastMsg}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding OrderStatus.Name, StringFormat=({0})}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0,10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding NextFollowup, StringFormat=F}" TextWrapping="Wrap" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Order Stage">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel x:Name="DisplayMode" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                        <TextBlock Text="{Binding OrderStatus.Name, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="btn_edit" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" CommandParameter="{Binding}" BorderThickness="0" Padding="5" Background="Transparent" Margin="5" Foreground="DimGray" FontSize="12">
                                            <icon:FontAwesome6 Kind="PencilSolid"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel x:Name="EditMode" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5" Visibility="Collapsed">
                                        <ComboBox x:Name="cbOStage" SelectedItem="{Binding OrderStatus, UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding ElementName=orderView, Path=OrderStages}" Width="60" VerticalAlignment="Center" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                                        <Button x:Name="btn_save" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" CommandParameter="{Binding}" BorderThickness="0" Padding="5" Background="Transparent" Margin="5" Foreground="Green" FontSize="12">
                                            <icon:FontAwesome6 Kind="CheckSolid"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter TargetName="DisplayMode" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="EditMode" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>                    
                    <!--<DataGridTemplateColumn Header="Extra Info" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Creation Date: " Grid.Row="0" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Last Updated: " Grid.Row="1" Grid.Column="0" FontSize="14" Margin="0" VerticalAlignment="Center"/>

                                    <TextBlock Text="{Binding Created, StringFormat=F}" TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Updated, StringFormat=F}" TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="Bold" Margin="0,10" VerticalAlignment="Center"/>

                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>-->
                    <!--<DataGridTextColumn Header="Lead Source" Binding="{Binding LeadSource.Name}" Width="*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Tags" Binding="{Binding Tags.Name}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Label" Binding="{Binding Label.Name}" Width="*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Status" Binding="{Binding Status.Name}" Width="*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="1.5*" IsReadOnly="True"/>-->
                    <!--<DataGridTextColumn Header="Important Date" Binding="{Binding ImpDate}" Width="*" IsReadOnly="True"/>-->

                    <DataGridTemplateColumn Header="Actions" Width="100" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Background="Transparent" Command="{Binding DataContext.PdfCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" CommandParameter="{Binding}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <icon:FontAwesome Kind="FilePdfSolid"/>
                                    </Button>
                                    <Button Background="Transparent" Command="{Binding DataContext.UpdateLeadCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <icon:FontAwesome Kind="PencilSolid"/>
                                    </Button>
                                    <Button Background="Transparent" Command="{Binding DataContext.DeleteLeadCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <icon:FontAwesome Kind="TrashSolid"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- Right Column: Lead Details / CRUD Form -->

    </Grid>
</UserControl>
