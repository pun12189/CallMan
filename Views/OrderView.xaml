<UserControl x:Class="BahiKitab.Views.OrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BahiKitab.Views"
xmlns:core="clr-namespace:BahiKitab.Core"
xmlns:icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
xmlns:helper="clr-namespace:BahiKitab.Helper"
             mc:Ignorable="d" x:Name="orderView"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <core:IdToButtonTextConverter x:Key="IdToButtonTextConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#20b2aa" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">

        <!-- Left Column: Leads List (DataGrid) -->
        <StackPanel Margin="0,0,10,0">
            <TextBlock Text="Orders" Style="{StaticResource TitleStyle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- Command Buttons for List -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Right">
                <Button Command="{Binding LoadLeadsCommand}" Style="{StaticResource KlikButtonStyle}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="RotateSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Refresh Orders" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding ImportOrdersCommand}" Style="{StaticResource KlikButtonStyle}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="DownloadSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Import Orders" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Command="{Binding NewLeadCommand}" Style="{StaticResource KlikButtonStyle}">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <icon:PackIconFontAwesome Kind="PlusSolid" Height="12" Width="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="New Order" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
            <!-- Data Grid to display Leads -->
            <DataGrid x:Name="dtGrid" ItemsSource="{Binding Leads}" 
              SelectedItem="{Binding SelectedLead, Mode=TwoWay}"
                  AlternatingRowBackground="Cornsilk"
              AutoGenerateColumns="False"
                  CanUserAddRows="False"
              Height="450"
              SelectionMode="Single"
                  ScrollViewer.CanContentScroll="True" 
  ScrollViewer.VerticalScrollBarVisibility="Auto"
  ScrollViewer.HorizontalScrollBarVisibility="Auto">                
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Info" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10">
                                    <TextBlock Text="{Binding Company, StringFormat=({0})}" FontSize="10" Margin="0,5,0,10" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding OrderId}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,5,0"/>
                                        <Button Visibility="Collapsed" BorderThickness="0" Command="{Binding DataContext.UpdateInfoCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" HorizontalAlignment="Center" Background="Transparent" Foreground="ForestGreen" FontWeight="Bold" Margin="0,0,5,0">
                                            <icon:BootstrapIcons Kind="PencilFill"/>
                                        </Button>
                                        <Button Visibility="Collapsed" BorderThickness="0" Command="{Binding DataContext.UpdateLeadCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" HorizontalAlignment="Center" Background="Transparent" Foreground="CornflowerBlue" FontWeight="Bold" Margin="0,0,5,0">
                                            <icon:BootstrapIcons Kind="Pen"/>
                                        </Button>
                                    </StackPanel>
                                    <Button BorderThickness="0" Content="Create Tasks" Command="{Binding DataContext.TaskCreateCommand, RelativeSource={RelativeSource AncestorType=local:OrderView}}" CommandParameter="{Binding}" HorizontalAlignment="Center" Background="Transparent" Foreground="ForestGreen" FontWeight="Bold" Margin="0,20,0,5">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTaskCreated, UpdateSourceTrigger=PropertyChanged}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Created, StringFormat={}{0:dd/MM/yyyy}}" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding Id, StringFormat=ID: {0}}" FontWeight="Bold" Margin="0,0,0,10"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!--<DataGridTemplateColumn Header="Contact" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <icon:PackIconFontAwesome Kind="PhoneSolid" Grid.Row="1" Grid.Column="0" FontSize="14" FontWeight="Bold"/>
                                    <icon:PackIconMaterial Kind="Email" Grid.Row="2" Grid.Column="0" FontSize="14" FontWeight="Bold"/>
                                    <icon:PackIconMaterial Kind="MapMarker" Grid.Row="3" Grid.Column="0" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Phone}" Grid.Row="1" Grid.Column="2" FontSize="14"/>
                                    <TextBlock Text="{Binding Email}" Grid.Row="2" Grid.Column="2" FontSize="14"/>
