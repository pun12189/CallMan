<Window x:Class="BahiKitab.Views.GenericImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BahiKitab.Views"
        mc:Ignorable="d"
        Title="Import Data Mapper" Height="600" Width="700" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="1. Map &amp; Clean Columns" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>

        <DataGrid Grid.Row="1" x:Name="dgMapping" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Database Field (Type to Create New)" 
                            Binding="{Binding DbColumnName, UpdateSourceTrigger=PropertyChanged}" 
                            Width="*"/>

                <DataGridTemplateColumn Header="Excel Source" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ExcelHeaders}" 
                                      SelectedItem="{Binding ExcelHeader, UpdateSourceTrigger=PropertyChanged}"
                                      SelectionChanged="CbExcelHeader_SelectionChanged"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="50">
                    <DataGridTemplateColumn.Header>
                        <Button Content="+" Click="BtnAddRow_Click" ToolTip="Add New Row" Cursor="Hand" Foreground="Black" Width="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="X" Background="Transparent" Foreground="Red" FontWeight="Bold" 
                                    BorderThickness="0" Click="BtnRemoveRow_Click" Cursor="Hand"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="2. Data Preview (First 5 Rows)" FontWeight="Bold" Margin="0,15,0,5"/>

        <DataGrid Grid.Row="3" x:Name="dgPreview" IsReadOnly="True" Background="#F0F0F0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" IsCancel="True" Width="80" Margin="0,0,10,0"/>
            <Button Content="Start Import" Click="BtnProcess_Click" Width="120" Background="Green" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
